# MinerU is required before running PDF conversion.
MINERU_API_TOKEN=
DASHSCOPE_API_KEY=

# Cloudflare Tunnel token for internal network deployment.
# Leave empty if not using Cloudflare Tunnel.
CLOUDFLARE_TUNNEL_TOKEN=

# Auth mode: basic (username/password) or none.
# VERITAS_AUTH_MODE=basic

# Log level: DEBUG, INFO, WARNING, ERROR.
# VERITAS_LOG_LEVEL=INFO

# Celery async task configuration.
# Broker uses PostgreSQL via sqlalchemy transport (no Redis required).
CELERY_BROKER_URL=sqlalchemy+postgresql://veritas:veritas@localhost:5432/veritas
CELERY_RESULT_BACKEND=db+postgresql://veritas:veritas@localhost:5432/veritas
AUDIT_MAX_CONCURRENT_JOBS=2
AUDIT_TASK_TIMEOUT_SECONDS=3600
# Set to true to enable Celery-based async audit; false uses synchronous execution.
VERITAS_USE_CELERY=false
