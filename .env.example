# MinerU is required before running PDF conversion.
MINERU_API_TOKEN=
DASHSCOPE_API_KEY=

# Cloudflare Tunnel token for internal network deployment.
# Leave empty if not using Cloudflare Tunnel.
CLOUDFLARE_TUNNEL_TOKEN=

# Auth mode: basic (username/password) or none.
# VERITAS_AUTH_MODE=basic

# Log level: DEBUG, INFO, WARNING, ERROR.
# VERITAS_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Database credentials — DO NOT hardcode in docker-compose files.
# Dev credentials are set here; production credentials go in deploy/.env.
# ---------------------------------------------------------------------------

# Local development (make dev + make db-up):
#   VERITAS_DATABASE_URL=postgresql://veritas_dev:veritas_dev_pass@localhost:5433/veritas_dev
#
# Production (deploy/docker-compose.yml reads from deploy/.env):
#   POSTGRES_DB=veritas_prod
#   POSTGRES_USER=veritas_prod
#   POSTGRES_PASSWORD=<strong-password>

# Celery async task configuration.
# Broker uses PostgreSQL via sqlalchemy transport (no Redis required).
# For Docker deployment, use 'postgres' as hostname; for local dev, use 'localhost'.
CELERY_BROKER_URL=sqlalchemy+postgresql://veritas_dev:veritas_dev_pass@localhost:5433/veritas_dev
CELERY_RESULT_BACKEND=db+postgresql://veritas_dev:veritas_dev_pass@localhost:5433/veritas_dev
AUDIT_MAX_CONCURRENT_JOBS=2
AUDIT_MAX_QUEUE_SIZE=10
AUDIT_TASK_TIMEOUT_SECONDS=3600
# Set to true to enable Celery-based async audit; false uses synchronous execution.
VERITAS_USE_CELERY=false
