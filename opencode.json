{
  "$schema": "https://opencode.ai/config.json",
  "model": "dashscope/qwen3.7-max",
  "small_model": "dashscope/qwen3.6-plus",
  "provider": {
    "dashscope": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Alibaba Cloud DashScope",
      "options": {
        "baseURL": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "apiKey": "{env:DASHSCOPE_API_KEY}"
      },
      "models": {
        "qwen3.7-max": {
          "name": "Qwen3.7 Max"
        },
        "qwen3.6-plus": {
          "name": "Qwen3.6 Plus"
        },
        "qwen3-vl-plus": {
          "name": "Qwen3 VL Plus"
        },
        "qwen3-vl-flash": {
          "name": "Qwen3 VL Flash"
        }
      }
    }
  },
  "instructions": [
    "AGENTS.md",
    ".opencode/skills/research-integrity-auditor/SKILL.md",
    "configs/opencode/veritas-agent.md",
    "configs/opencode/biomed-research-audit-methodology.md",
    "configs/methodology/general.md",
    "configs/methodology/source-data.md",
    "configs/methodology/biomed-wetlab.md",
    "configs/methodology/bioinfo.md",
    "configs/methodology/visual-forensics.md"
  ],
  "permission": {
    "skill": {
      "research-integrity-auditor": "allow",
      "*": "ask"
    },
    "bash": "ask",
    "edit": "ask"
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "outputs/**",
      "input/**",
      "node_modules/**",
      "third_party/**/.git/**"
    ]
  },
  "share": "disabled",
  "autoupdate": "notify"
}
