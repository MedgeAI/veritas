# Optional opencode server settings.
# Copy values into the project root .env or export them in your shell.

OPENCODE_HOST=127.0.0.1
OPENCODE_PORT=4096

# Recommended if binding to anything other than localhost.
# OPENCODE_SERVER_USERNAME=opencode
# OPENCODE_SERVER_PASSWORD=change-me

# Comma-separated browser origins. Example:
# OPENCODE_CORS=http://localhost:5173,http://127.0.0.1:5173

# Provider credentials should stay in local env only.
# DASHSCOPE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# MinerU is required before running PDF conversion.
# MINERU_API_TOKEN=
