# syntax=docker/dockerfile:1
#
# Veritas 开发镜像（GPU + 热重载）
#
# 打进镜像（变化极少，Docker 层缓存）：
#   CUDA 12.1 + Python 3.12 + PyTorch 2.5.1 runtime
#   Node.js 20 + opencode CLI
#   系统工具 + pip 依赖 (uv sync --frozen)
#
# 运行时挂载（频繁变化/体积大）：
#   ./         → /workspace  (代码，uvicorn --reload 热重载)
#   outputs/   → /app/outputs
#   web_data/  → /app/web_data
#   models/    → /app/models (权重 ~1GB+，独立管理)
#   .env       (密钥)
#
# 构建（首次 ~5 分钟，后续秒级）：
#   docker compose -f docker-compose.dev.yml build backend
#
# 模型权重不进镜像。运行前确保本地 models/ 目录有：
#   models/trufor/weights/trufor.pth.tar    (~269MB)
#   models/sscd/sscd_disc_mixup.torchscript.pt
#   models/panel_extraction/*.pt            (~540MB)
#   脚本：make download-models

# ── Layer 1: CUDA + Python + PyTorch ────────────────────────────────────
FROM pytorch/pytorch:2.5.1-cuda12.1-cudnn9-runtime

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# 系统依赖 + Node.js (opencode CLI)
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        curl git ca-certificates && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# opencode CLI（单独 layer，版本不变就不重建）
RUN npm install -g opencode-ai@latest

# ── Layer 2: Python 依赖 (lock 不变就不重建) ────────────────────────────
WORKDIR /app

COPY pyproject.toml uv.lock ./
RUN pip install -q uv && \
    uv sync --frozen --no-dev --all-extras

# ── Layer 3: 运行时配置 ────────────────────────────────────────────────

# 创建非 root 用户（与宿主机 UID 对齐，避免 bind mount 权限问题）
ARG USERNAME=veritas
ARG USER_UID=1000
ARG USER_GID=$USER_UID

RUN groupadd --gid $USER_GID $USERNAME \
    && useradd --uid $USER_UID --gid $USER_GID --shell /bin/bash --create-home $USERNAME

RUN mkdir -p /app/models /app/outputs /app/web_data \
    && chown -R $USERNAME:$USERNAME /app \
    # uv 在 Layer 2 以 root 身份写入 /.cache/uv，构建期把所有权交给非 root 用户
    && chown -R $USERNAME:$USERNAME /.cache

ENV VERITAS_HOST=0.0.0.0 \
    VERITAS_PORT=8765 \
    VERITAS_DATA_ROOT=/app/web_data \
    VERITAS_OUTPUT_ROOT=/app/outputs \
    VERITAS_DATABASE_URL=postgresql://veritas:veritas@postgres:5432/veritas \
    PYTHONPATH=/workspace \
    TZ=Asia/Shanghai

EXPOSE 8765

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8765/api/health || exit 1

# 以非 root 身份运行
USER $USERNAME

# uvicorn + watchfiles 热重载：监听 /workspace 下代码变更
CMD ["uv", "run", "python", "-m", "uvicorn", \
     "web.backend.veritas_web.app:get_app", \
     "--factory", "--host", "0.0.0.0", "--port", "8765", \
     "--reload", "--reload-dir", "/workspace/web/backend", \
     "--reload-dir", "/workspace/engine", \
     "--reload-exclude", "*/__pycache__/*"]
